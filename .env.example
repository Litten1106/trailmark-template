# Mapbox access token (public, scoped for browser use).
# Create at https://account.mapbox.com/access-tokens/
PUBLIC_MAPBOX_ACCESS_TOKEN=

# Optional: custom Mapbox style URL
# PUBLIC_MAPBOX_STYLE=mapbox://styles/mapbox/streets-v12

# Optional: bias geocoding to a country (ISO 3166-1 alpha-2)
# GEOCODE_COUNTRY=JP
